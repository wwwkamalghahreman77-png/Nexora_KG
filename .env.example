# توکن رباتت رو از BotFather بگیر
BOT_TOKEN=123456:ABC-your-bot-token

# آیدی عددی تلگرام خودت (یا چند نفر با کاما جدا) برای دسترسی به دستورات ادمین
# آیدی عددی رو می‌تونی از @userinfobot بگیری
ADMIN_IDS=123456789

# برای شروع نیازی به تغییر نیست - SQLite به‌صورت خودکار ساخته میشه
DATABASE_URL=sqlite:///rail_network.db
